# LITTLEFUN Backend Configuration
# ═══════════════════════════════════════════════

# Backend Port
PORT=3001

# Gmail SMTP Settings (Email Doğrulama İçin)
# 1. Gmail hesabınızda 2FA'yı açın
# 2. Google App Password oluşturun: https://myaccount.google.com/apppasswords
# 3. Aşağıya bilgilerinizi girin
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
